# ── App ───────────────────────────────────────────────────────────────────
APP_ENV=development              # development | staging | production
APP_NAME=trade-ai-server
APP_VERSION=0.1.0

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Security ──────────────────────────────────────────────────────────────
# Dev default — change this for staging/production!
API_TOKEN=dev-token-change-me
ADMIN_PASSWORD=admin-change-me

# ── AI Provider ───────────────────────────────────────────────────────────
# openai | deepseek | anthropic | mock
#
# Safe local default: mock returns WAIT without calling any external API.
# For live trading, switch to deepseek and uncomment the API key below.
AI_PROVIDER=mock

# DeepSeek — kullanmak için AI_PROVIDER=deepseek yapıp aşağıdaki satırları açın
#DEEPSEEK_API_KEY=your-deepseek-api-key-here
#DEEPSEEK_MODEL=deepseek-chat

# ── Database ──────────────────────────────────────────────────────────────
# Development: leave empty to use SQLite (dev.db). No setup needed.
#DATABASE_URL=sqlite+aiosqlite:///./dev.db

# Production: PostgreSQL required. Cannot be empty and cannot be SQLite.
#DATABASE_URL=postgresql+asyncpg://trade_ai:${POSTGRES_PASSWORD}@postgres:5432/trade_ai
POSTGRES_PASSWORD=change-me-in-production

# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=

# ── Trading ───────────────────────────────────────────────────────────────
# paper | live
DEFAULT_MODE=paper

# Risk controls
RISK_DISABLE_TRADING_AFTER=17:30
RISK_TIMEZONE=Europe/Istanbul
