# =============================================================================
# .env — SADECE kimlik/bağlantı tanımları burada tutulur.
#
# Tüm davranış ayarları (işlem modu, emir izinleri, risk limitleri, tarama
# aralıkları, sembol listeleri...) admin panelden yönetilir:
#     http://localhost:8000/admin/config
#
# Burada görülen davranış anahtarları (SCANNER_*, RISK_*, DEFAULT_MODE)
# yalnızca panelde henüz kaydedilmemiş ayarların İLK varsayılanını belirler.
# Panelden bir değer kaydedildiği anda kalıcı olarak panel değeri geçerli
# olur ve buradaki değer artık okunmaz.
# =============================================================================

# ── Uygulama tanımı ──────────────────────────────────────────────────────────
APP_ENV=development              # development | staging | production
APP_NAME=trade-ai-server
APP_VERSION=0.1.0

# ── Sunucu ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
CORS_ORIGINS=*

# ── Güvenlik: API anahtarları ve parolalar (SADECE burada) ──────────────────
# Dev varsayılanı — staging/production için mutlaka değiştirin!
API_TOKEN=dev-token-change-me
EVALUATION_API_TOKEN=
GATEWAY_API_TOKEN=
ADMIN_API_TOKEN=
ADMIN_PASSWORD=admin-change-me

# ── AI sağlayıcı kimliği ─────────────────────────────────────────────────────
# mock | deepseek. mock hiçbir dış API çağırmaz, her zaman WAIT döner.
AI_PROVIDER=mock
#DEEPSEEK_API_KEY=your-deepseek-api-key-here
#DEEPSEEK_MODEL=deepseek-chat

# ── Veritabanı bağlantısı ────────────────────────────────────────────────────
# Development: boş bırakılırsa SQLite (dev.db) kullanılır.
#DATABASE_URL=sqlite+aiosqlite:///./dev.db
# Production: PostgreSQL zorunlu.
#DATABASE_URL=postgresql+asyncpg://trade_ai:change-me-in-production@localhost:5432/trade_ai

# ── Telegram bildirimleri (kimlik) ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=

# ── Matriks Gateway bağlantısı ───────────────────────────────────────────────
# Aynı makinede Matriks IQ içinde çalışan TradeAiGateway algo'sunun adresi.
# Gateway sadece loopback'te dinler — URL her zaman 127.0.0.1 olmalı.
MATRIKS_GATEWAY_URL=http://127.0.0.1:8787
# TradeAiGateway.cs'teki ApiToken parametresiyle AYNI değer olmalı.
MATRIKS_GATEWAY_TOKEN=change-me-gateway-token

# ── Süreç başlatma tanımları (yeniden başlatma gerektirir) ──────────────────
# Tarama döngüsü arka plan görevi hiç başlatılsın mı? false ise panel dahil
# hiçbir şey tarayamaz. Çalışan taramayı geçici duraklatmak için paneldeki
# "Tarayıcı Aktif" (scannerEnabled) anahtarını kullanın — restart gerekmez.
SCANNER_ENABLED=false
SCANNER_TICK_SECONDS=60
POSITION_SYNC_ENABLED=true
POSITION_SYNC_INTERVAL_SECONDS=60
ORDER_SYNC_ENABLED=true
ORDER_SYNC_INTERVAL_SECONDS=900
ORDER_PENDING_TIMEOUT_MINUTES=15

# ── Panel varsayılanları (panelde kayıt yoksa geçerli olan İLK değerler) ────
# Bunları burada değiştirmek yerine admin panelden yönetin.
DEFAULT_MODE=paper               # panel karşılığı: "İşlem Modu" (tradingMode)
SCANNER_ALLOW_ORDERS=false       # panel karşılığı: "Tarayıcı Emir Gönderebilir"
MANUAL_APPROVAL_ALLOW_ORDERS=false  # panel karşılığı: "Manuel Onaylı Emirlere İzin"
RISK_DISABLE_TRADING_AFTER=17:30 # panel karşılığı: "İşlem Kesim Saati"
RISK_TIMEZONE=Europe/Istanbul    # panel karşılığı: "Saat Dilimi"
