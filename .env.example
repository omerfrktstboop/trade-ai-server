# ── App ───────────────────────────────────────────────────────────────────
APP_ENV=development              # development | staging | production
APP_NAME=trade-ai-server
APP_VERSION=0.1.0

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Security ──────────────────────────────────────────────────────────────
# Dev default — change this for staging/production!
API_TOKEN=dev-token-change-me

# ── AI Provider ───────────────────────────────────────────────────────────
# openai | deepseek | anthropic
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/trade_ai

# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=

# ── Trading ───────────────────────────────────────────────────────────────
# paper | live
DEFAULT_MODE=paper
