# ── App ───────────────────────────────────────────────────────────────────
APP_ENV=development              # development | staging | production
APP_NAME=trade-ai-server
APP_VERSION=0.1.0

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Security ──────────────────────────────────────────────────────────────
# Dev default — change this for staging/production!
API_TOKEN=dev-token-change-me
ADMIN_PASSWORD=admin-change-me

# ── AI Provider ───────────────────────────────────────────────────────────
# openai | deepseek | anthropic | mock
#
# Safe local default: mock returns WAIT without calling any external API.
# For live trading, switch to deepseek and uncomment the API key below.
AI_PROVIDER=mock

# DeepSeek — kullanmak için AI_PROVIDER=deepseek yapıp aşağıdaki satırları açın
#DEEPSEEK_API_KEY=your-deepseek-api-key-here
#DEEPSEEK_MODEL=deepseek-chat

# ── Database ──────────────────────────────────────────────────────────────
# Development: leave empty to use SQLite (dev.db). No setup needed.
#DATABASE_URL=sqlite+aiosqlite:///./dev.db

# Production: PostgreSQL required. Cannot be empty and cannot be SQLite.
#DATABASE_URL=postgresql+asyncpg://trade_ai:${POSTGRES_PASSWORD}@postgres:5432/trade_ai
POSTGRES_PASSWORD=change-me-in-production

# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=

# ── Trading ───────────────────────────────────────────────────────────────
# paper | live
DEFAULT_MODE=paper

# Risk controls
RISK_DISABLE_TRADING_AFTER=17:30
RISK_TIMEZONE=Europe/Istanbul

# ── Matriks Gateway (full-inversion) ─────────────────────────────────────
# Aynı makinede Matriks IQ içinde çalışan TradeAiGateway algo'sunun adresi.
# Gateway sadece loopback'te dinler — URL her zaman 127.0.0.1 olmalı.
MATRIKS_GATEWAY_URL=http://127.0.0.1:8787
# TradeAiGateway.cs'teki ApiToken parametresiyle AYNI değer olmalı.
MATRIKS_GATEWAY_TOKEN=change-me-gateway-token

# ── Scanner (server-side tarama döngüsü) ──────────────────────────────────
# true → server, gateway üzerinden sembolleri periyodik tarayıp karar üretir.
# Acil durumda false yapmak tüm otomasyonu keser (kill switch'e ek fren).
SCANNER_ENABLED=false
SCANNER_TICK_SECONDS=60

# false → tüm kararlar PAPER'a sabit, emir yolu kapalı (güvenli default).
# true  → mod admin panelin tradingMode ayarından gelir ve sadece DEMO_LIVE
#         kararları gateway'e LIMIT emir olarak gönderilir.
#         REAL_LIVE scanner'da Phase 2 boyunca kod seviyesinde bloklu.
SCANNER_ALLOW_ORDERS=false
